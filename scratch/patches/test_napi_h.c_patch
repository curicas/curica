--- src/napi.h
+++ src/napi.h
@@ -83,16 +83,40 @@
 
 
 // Core API declarations
+#ifdef CURICA_RUNTIME
 napi_status napi_get_undefined(napi_env env, napi_value* result);
 napi_status napi_get_null(napi_env env, napi_value* result);
-
 napi_status napi_create_int32(napi_env env, int32_t value, napi_value* result);
 napi_status napi_create_string_utf8(napi_env env, const char* str, size_t length, napi_value* result);
-
 napi_status napi_create_object(napi_env env, napi_value* result);
 napi_status napi_create_function(napi_env env, const char* utf8name, size_t length, napi_callback cb, void* data, napi_value* result);
-
 napi_status napi_set_named_property(napi_env env, napi_value object, const char* utf8name, napi_value value);
 napi_status napi_get_named_property(napi_env env, napi_value object, const char* utf8name, napi_value* result);
-
 napi_status napi_get_cb_info(napi_env env, napi_callback_info cbinfo, size_t* argc, napi_value* argv, napi_value* this_arg, void** data);
+#endif
+
+typedef struct NapiApiTable {
+    napi_status (*get_undefined)(napi_env env, napi_value* result);
+    napi_status (*get_null)(napi_env env, napi_value* result);
+    napi_status (*create_int32)(napi_env env, int32_t value, napi_value* result);
+    napi_status (*create_string_utf8)(napi_env env, const char* str, size_t length, napi_value* result);
+    napi_status (*create_object)(napi_env env, napi_value* result);
+    napi_status (*create_function)(napi_env env, const char* utf8name, size_t length, napi_callback cb, void* data, napi_value* result);
+    napi_status (*set_named_property)(napi_env env, napi_value object, const char* utf8name, napi_value value);
+    napi_status (*get_named_property)(napi_env env, napi_value object, const char* utf8name, napi_value* result);
+    napi_status (*get_cb_info)(napi_env env, napi_callback_info cbinfo, size_t* argc, napi_value* argv, napi_value* this_arg, void** data);
+} NapiApiTable;
+
+struct napi_env__ {
+    NapiApiTable* api;
+};
+
+#ifndef CURICA_RUNTIME
+#define napi_get_undefined(env, res) (env)->api->get_undefined((env), (res))
+#define napi_get_null(env, res) (env)->api->get_null((env), (res))
+#define napi_create_int32(env, val, res) (env)->api->create_int32((env), (val), (res))
+#define napi_create_string_utf8(env, str, len, res) (env)->api->create_string_utf8((env), (str), (len), (res))
+#define napi_create_object(env, res) (env)->api->create_object((env), (res))
+#define napi_create_function(env, name, len, cb, data, res) (env)->api->create_function((env), (name), (len), (cb), (data), (res))
+#define napi_set_named_property(env, obj, name, val) (env)->api->set_named_property((env), (obj), (name), (val))
+#define napi_get_named_property(env, obj, name, res) (env)->api->get_named_property((env), (obj), (name), (res))
+#define napi_get_cb_info(env, info, argc, argv, this_arg, data) (env)->api->get_cb_info((env), (info), (argc), (argv), (this_arg), (data))
+#endif
